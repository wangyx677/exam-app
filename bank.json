: "以下（  ）属于定向施工前应准备的资料。", "options": ["地质设计书", "钻井工程设计书", "邻井防碰资料", "完井报告模板"], "answer": [0, 1, 2], "analysis": ""}, {"id": 135, "type": "multi", "chapter": "综合题库", "stem": "定向施工中，（  ）情况不应投测电子单多点。", "options": ["悬重不正常", "泵压不正常", "井下不正常", "钻井设备不正常"], "answer": [0, 1, 2, 3], "analysis": ""}, {"id": 136, "type": "multi", "chapter": "综合题库", "stem": "以下（  ）属于MW4地面设备。", "options": ["压力传感器", "专用数据处理仪", "定向探管", "远程数据处理器"], "answer": [0, 1, 3], "analysis": ""}, {"id": 137, "type": "multi", "chapter": "综合题库", "stem": "以下（  ）是定向井常用的井身剖面类型。", "options": ["直-增（两段制）", "直-增-稳（三段制）", "直-增-降（四段制）", "直-增-稳-降-直（五段制）"], "answer": [0, 1, 3], "analysis": ""}, {"id": 138, "type": "multi", "chapter": "综合题库", "stem": "以下（  ）属于海蓝YST-48R井下仪器的组成部分。", "options": ["定向探管", "伽马探管", "泥浆脉冲发生器", "压力传感器"], "answer": [0, 1, 2], "analysis": ""}, {"id": 139, "type": "multi", "chapter": "综合题库", "stem": "以下（  ）措施可降低定向井施工中的防碰风险。", "options": ["收集齐全防碰井资料", "使用牙轮钻头钻进高风险井段", "忽略老井数据", "施工中密切观察磁场参数变化"], "answer": [0, 1, 3], "analysis": ""}, {"id": 140, "type": "multi", "chapter": "综合题库", "stem": "以下（  ）属于定向施工中的风险识别内容。", "options": ["员工健康风险", "用电安全风险", "井控及硫化氢泄露风险", "数据录入错误风险"], "answer": [0, 1, 2, 3], "analysis": ""}, {"id": 141, "type": "multi", "chapter": "综合题库", "stem": "以下（  ）是水平井按曲率半径分类的类型。", "options": ["短半径水平井", "中半径水平井", "长半径水平井", "超长半径水平井"], "answer": [0, 1, 2], "analysis": ""}, {"id": 142, "type": "multi", "chapter": "综合题库", "stem": "以下（  ）属于定向井轨迹图示方法。", "options": ["三维坐标图示法", "投影图示法", "柱面图示法", "剖面图示法"], "answer": [0, 1, 2], "analysis": ""}, {"id": 143, "type": "multi", "chapter": "综合题库", "stem": "以下（  ）属于定向施工中应遵守的“四不侧钻”原则。", "options": ["井底不干净不侧钻", "井眼不畅通不侧钻", "井下有复杂情况不侧钻", "螺杆运转和测量仪器不正常不侧钻"], "answer": [0, 1, 2, 3], "analysis": ""}, {"id": 144, "type": "multi", "chapter": "综合题库", "stem": "目前现场常用的荧光录井方法主要有（  ）等方法。", "options": ["滴酸反应", "滴照", "系列对比", "岩屑干照"], "answer": [1, 2, 3], "analysis": ""}, {"id": 145, "type": "multi", "chapter": "综合题库", "stem": "进入水平段后，当地层倾角发生变化时，对井斜角进行调整，井斜角的调整应考虑（  ）之间的匹配关系。", "options": ["井斜角", "方位角", "地层倾角", "井底垂深"], "answer": [0, 2], "analysis": ""}, {"id": 146, "type": "multi", "chapter": "综合题库", "stem": "将全部录井岩屑系统地逐包置于荧光灯下观察，看是否有荧光显示。下列属于含油岩屑在紫外光下呈现的颜色有（  ）。", "options": ["浅黄色", "黄色", "棕色", "黑色"], "answer": [0, 1, 2], "analysis": ""}, {"id": 147, "type": "multi", "chapter": "综合题库", "stem": "工程异常中刺泵的参数特征包括（  ）。", "options": ["泵冲正常情况下，立管压力缓慢下降，出口流量减小", "钻时增大", "立管压力升高，出口流量增大", "钻时降低"], "answer": [0, 1], "analysis": ""}, {"id": 148, "type": "multi", "chapter": "综合题库", "stem": "断层的几何要素包括（  ）。", "options": ["断层面", "断盘", "位移", "倾角"], "answer": [0, 1, 2], "analysis": ""}, {"id": 149, "type": "multi", "chapter": "综合题库", "stem": "X射线元素录井的主要应用是（  ）。", "options": ["岩性识别", "地层对比", "识别有机质", "判断沉积环境"], "answer": [0, 1, 3], "analysis": ""}, {"id": 150, "type": "judge", "chapter": "综合题库", "stem": "常用丛式井防碰分析计算方法有三种，即水平面法、最近距离法、法平面法。", "options": ["正确", "错误"], "answer": 0, "analysis": ""}, {"id": 151, "type": "judge", "chapter": "综合题库", "stem": "MW4仪器无信号时可采取提高转速，上下大幅度活动等措施。", "options": ["正确", "错误"], "answer": 0, "analysis": ""}, {"id": 152, "type": "judge", "chapter": "综合题库", "stem": "使用过的废旧锂电池组应及时回收，不得在现场长时间囤积废旧锂电池组。", "options": ["正确", "错误"], "answer": 0, "analysis": ""}, {"id": 153, "type": "judge", "chapter": "综合题库", "stem": "侧钻造台阶前，先做防粘卡试验：3分钟、5分钟、10分钟、15分钟和30分钟各一次，确定井下安全后，开始造台阶。", "options": ["正确", "错误"], "answer": 0, "analysis": ""}, {"id": 154, "type": "judge", "chapter": "综合题库", "stem": "使用过的锂电池电量低，因此无安全风险。", "options": ["正确", "错误"], "answer": 1, "analysis": "使用过的锂电池因结构劣化与化学失稳易引发安全事故。"}, {"id": 155, "type": "judge", "chapter": "综合题库", "stem": "随钻震击器能够产生正常震击负荷即可，对其在钻具中安放位置并无特殊要求。", "options": ["正确", "错误"], "answer": 1, "analysis": "钻井震击器在井下钻具组合中的安装位置需根据具体作业需求设计，原则是确保震击能量高效传递至卡点，同时不影响其他工具功能。"}, {"id": 156, "type": "judge", "chapter": "综合题库", "stem": "旋导施工卡钻风险小于常规螺杆钻具组合。", "options": ["正确", "错误"], "answer": 1, "analysis": "旋导施工的井眼扩大率相对螺杆钻具组合的要小，因此卡钻风险更高。"}, {"id": 157, "type": "judge", "chapter": "综合题库", "stem": "螺杆钻具是以泥浆为动力的一种井下工具，其由传动轴总成、马达总成、万向轴总成、防掉总成和旁通阀总成五大部分组成。", "options": ["正确", "错误"], "answer": 0, "analysis": ""}, {"id": 158, "type": "judge", "chapter": "综合题库", "stem": "井控工作要求定向钻具组合中必须安装钻具止回阀，并符合钻井施工设计要求，否则定向技术人员有权拒绝下步施工。", "options": ["正确", "错误"], "answer": 0, "analysis": ""}, {"id": 159, "type": "judge", "chapter": "综合题库", "stem": "钻具入井前应进行外观检查，并测绘打捞尺寸，确保井下安全以及在事故发生后能有效、快速处理。", "options": ["正确", "错误"], "answer": 0, "analysis": ""}, {"id": 160, "type": "judge", "chapter": "综合题库", "stem": "如果起钻速度足够慢就可以消除抽吸现象。", "options": ["正确", "错误"], "answer": 1, "analysis": "起钻速度慢可以降低抽吸现象。"}, {"id": 161, "type": "judge", "chapter": "综合题库", "stem": "弯曲应力较大时，钻柱在旋转工况下发生应力交变，将加剧钻柱的疲劳破坏。", "options": ["正确", "错误"], "answer": 0, "analysis": ""}, {"id": 162, "type": "judge", "chapter": "综合题库", "stem": "造成压差卡钻的原因有钻井液密度高、润滑性能差、液柱压差大、地层渗透性好、钻井液滤失量大、钻具在井内静止时间长等多种原因。", "options": ["正确", "错误"], "answer": 0, "analysis": ""}, {"id": 163, "type": "judge", "chapter": "综合题库", "stem": "定向在钻台指导钻井队施工时，应站在司钻右后侧或司钻房内等安全区域内。", "options": ["正确", "错误"], "answer": 0, "analysis": ""}, {"id": 164, "type": "judge", "chapter": "综合题库", "stem": "溢流发生的根本原因是起下钻产生的波动压力。", "options": ["正确", "错误"], "answer": 1, "analysis": "根本原因是地层压力大于钻井液压力。"}, {"id": 165, "type": "judge", "chapter": "综合题库", "stem": "钻具下部组合的定向钻具、钻铤、扶正器、震击器、加重钻杆应定期探伤，防止断钻具。", "options": ["正确", "错误"], "answer": 0, "analysis": ""}, {"id": 166, "type": "judge", "chapter": "综合题库", "stem": "投测多点过程中，当井下异常需开泵时，可不用考虑抗压筒的抗压性能及密封性。", "options": ["正确", "错误"], "answer": 1, "analysis": "应考虑抗压筒的抗压性能及密封性。"}, {"id": 167, "type": "judge", "chapter": "综合题库", "stem": "为了节约时间，在下随钻MW4仪器时，可以不灌泥浆。", "options": ["正确", "错误"], "answer": 1, "analysis": "下随钻MW4仪器时，应按要求灌浆。"}, {"id": 168, "type": "judge", "chapter": "综合题库", "stem": "现场录井人员应加强地质分析，在钻开油气层前向井队提出预告。钻开油气层后，每次起下钻均应进行后效录井，测量油气上窜速度等。", "options": ["正确", "错误"], "answer": 0, "analysis": ""}, {"id": 169, "type": "judge", "chapter": "综合题库", "stem": "在对岩屑、岩心样进行紫外线直照（干照、湿照）试验、点滴实验、标准系列对比试验时，由于荧光灯紫外线强度较小，不用防止紫外线对人体造成伤害。", "options": ["正确", "错误"], "answer": 1, "analysis": "需要防范紫外线伤害。"}, {"id": 170, "type": "judge", "chapter": "综合题库", "stem": "在中途测试作业过程中，录井人员应避开高压管汇、阀门等危险区域，并做好有毒有害气体的检测与防护。", "options": ["正确", "错误"], "answer": 0, "analysis": ""}, {"id": 171, "type": "judge", "chapter": "综合题库", "stem": "对起下钻过程中的灌浆情况，录井队不需要提醒钻井队。", "options": ["正确", "错误"], "answer": 1, "analysis": "录井队监控、提示钻井队灌浆情况。"}, {"id": 172, "type": "judge", "chapter": "综合题库", "stem": "各警报器安装连接后应通电试验声光报警是否正常。", "options": ["正确", "错误"], "answer": 0, "analysis": ""}, {"id": 173, "type": "judge", "chapter": "综合题库", "stem": "增压防爆装置连接时，管线接口不需要做密封处理。", "options": ["正确", "错误"], "answer": 1, "analysis": "管线接口需要密封处理。"}, {"id": 174, "type": "judge", "chapter": "综合题库", "stem": "增压防爆系统的进气端口应设置在安全的空旷地带。", "options": ["正确", "错误"], "answer": 0, "analysis": ""}, {"id": 175, "type": "judge", "chapter": "综合题库", "stem": "录井参数变化应采用不同的方式予以报警提示。", "options": ["正确", "错误"], "answer": 0, "analysis": ""}, {"id": 176, "type": "judge", "chapter": "综合题库", "stem": "录井房内增压表指示突然回零，可能原因是鼓风机停止工作。", "options": ["正确", "错误"], "answer": 0, "analysis": ""}, {"id": 177, "type": "judge", "chapter": "综合题库", "stem": "在电源电缆连接良好且供电正常情况下，按下非烃检测仪电源开关电源指示灯不亮，最可能的原因是电源开关坏。", "options": ["正确", "错误"], "answer": 1, "analysis": "可能是电源指示灯或电源开关损坏。"}, {"id": 178, "type": "judge", "chapter": "综合题库", "stem": "录井队仪器房、值班房和宿舍房均应安装漏电保护器和接地装置。", "options": ["正确", "错误"], "answer": 0, "analysis": ""}, {"id": 179, "type": "judge", "chapter": "综合题库", "stem": "录井仪器房、值班房和宿舍房不应摆放在填筑土方上、陡崖下、悬崖边、易滑坡、垮塌及洪汛影响的地方。", "options": ["正确", "错误"], "answer": 0, "analysis": ""}, {"id": 180, "type": "judge", "chapter": "综合题库", "stem": "录井施工过程中的废弃物产生量很少，可以随意处理。", "options": ["正确", "错误"], "answer": 1, "analysis": "不能随意处理。"}, {"id": 181, "type": "judge", "chapter": "综合题库", "stem": "使用酒精灯加热时，试管口可以朝向操作人员。", "options": ["正确", "错误"], "answer": 1, "analysis": "试管口不得朝向操作人员。"}, {"id": 182, "type": "judge", "chapter": "综合题库", "stem": "录井施工与其他工程交叉施工作业过程中，录井人员可以进入危险区域。", "options": ["正确", "错误"], "answer": 1, "analysis": "录井人员不得进入危险区域。"}, {"id": 183, "type": "judge", "chapter": "综合题库", "stem": "岩心出筒时，操作人员站于岩心筒正面，可以用手掌直接接岩心。", "options": ["正确", "错误"], "answer": 1, "analysis": "不得用手捧接岩心。"}, {"id": 184, "type": "judge", "chapter": "综合题库", "stem": "综合录井仪控制系统的漏电保护器配置主要针对内部用电设备，一旦发生漏电，立即切断供电，保护综合录井仪和各用电设备。", "options": ["正确", "错误"], "answer": 0, "analysis": ""}, {"id": 185, "type": "judge", "chapter": "综合题库", "stem": "增压防爆式综合录井仪控制系统，主电源控制箱除了引入外部交流电外，还有一项功能就是检测录井房内压力，当不满足增压防爆要求时，自动切断外部供电。", "options": ["正确", "错误"], "answer": 0, "analysis": ""}, {"id": 186, "type": "judge", "chapter": "综合题库", "stem": "氢气发生器应保持排气畅通，并定期检漏，防止氢气泄漏。", "options": ["正确", "错误"], "answer": 0, "analysis": ""}, {"id": 187, "type": "judge", "chapter": "综合题库", "stem": "室内标定硫化氢传感器时，应保持空气流通。", "options": ["正确", "错误"], "answer": 0, "analysis": ""}, {"id": 188, "type": "judge", "chapter": "综合题库", "stem": "录井施工过程中应定期检查空气压缩机安全阀、气路。", "options": ["正确", "错误"], "answer": 0, "analysis": ""}, {"id": 189, "type": "judge", "chapter": "综合题库", "stem": "安装、调试、维修与保养绞车传感器前，不用先切断滚筒动力和导气龙头气源。", "options": ["正确", "错误"], "answer": 1, "analysis": "应先切断滚筒动力和导气龙头气源。"}, {"id": 190, "type": "judge", "chapter": "综合题库", "stem": "安装、调试、维修与保养转盘转速、扭矩传感器前，应切断转盘动力。", "options": ["正确", "错误"], "answer": 0, "analysis": ""}, {"id": 191, "type": "judge", "chapter": "综合题库", "stem": "安装、调试、维修与保养立管压力传感器前，应先停泵，排空立管内钻井液；安装结束后须经钻井队技术人员确认，方可通知开泵。", "options": ["正确", "错误"], "answer": 0, "analysis": ""}, {"id": 192, "type": "judge", "chapter": "综合题库", "stem": "安装、调试、维修与保养泵冲传感器前，不用停泥浆泵。", "options": ["正确", "错误"], "answer": 1, "analysis": "在停泵期间作业"}, {"id": 193, "type": "judge", "chapter": "综合题库", "stem": "录井电源线和信号线要分开架设。", "options": ["正确", "错误"], "answer": 0, "analysis": ""}, {"id": 194, "type": "judge", "chapter": "综合题库", "stem": "录井烘烤箱可以和其他设备共用一个漏电保护开关。", "options": ["正确", "错误"], "answer": 1, "analysis": "录井烘烤箱应采用独立漏电保护开关。"}, {"id": 195, "type": "judge", "chapter": "综合题库", "stem": "井场距井口30米以内的电气系统：包括电机、开关、照明灯具、仪器仪表、电器线路及接插件、各种电动工具等在内的所有电气设备均应符合防爆要求。", "options": ["正确", "错误"], "answer": 0, "analysis": ""}, {"id": 196, "type": "judge", "chapter": "综合题库", "stem": "可燃物质及有机溶剂不应放置在热源附近。", "options": ["正确", "错误"], "answer": 0, "analysis": ""}, {"id": 197, "type": "judge", "chapter": "综合题库", "stem": "录井仪器房、地质值班房内不应存放非试验用易燃易爆物品。", "options": ["正确", "错误"], "answer": 0, "analysis": ""}, {"id": 198, "type": "judge", "chapter": "综合题库", "stem": "在丈量方入时，应先确认已关停转盘，作业人员严禁站在转盘面上操作。", "options": ["正确", "错误"], "answer": 0, "analysis": ""}, {"id": 199, "type": "judge", "chapter": "综合题库", "stem": "腐蚀性及易燃易爆物品不得在烘样箱内烘烤。", "options": ["正确", "错误"], "answer": 0, "analysis": ""}, {"id": 200, "type": "judge", "chapter": "综合题库", "stem": "综合录井仪器房接地体使用金属棒，打入潮湿地下不小于0.6m，接地导线电阻不大于4Ω。", "options": ["正确", "错误"], "answer": 0, "analysis": ""}, {"id": 201, "type": "judge", "chapter": "综合题库", "stem": "使用有毒试剂时，应佩戴专用手套及防护口罩。", "options": ["正确", "错误"], "answer": 0, "analysis": ""}, {"id": 202, "type": "judge", "chapter": "综合题库", "stem": "二氧化碳灭火器用于一般电气火灾，因此录井仪器房内应配备二氧化碳灭火器。", "options": ["正确", "错误"], "answer": 0, "analysis": ""}, {"id": 203, "type": "judge", "chapter": "综合题库", "stem": "仪器房内在用的二氧化碳灭火器重量应为铭牌标注重量的95%以上。", "options": ["正确", "错误"], "answer": 0, "analysis": ""}, {"id": 204, "type": "judge", "chapter": "综合题库", "stem": "应急预案启动后，所有施工人员必须立即撤离施工区域。", "options": ["正确", "错误"], "answer": 1, "analysis": "人员应按照分工进行应急处置，其余人员在撤离到应急集合点。"}, {"id": 205, "type": "judge", "chapter": "综合题库", "stem": "脱气器安装，高度以脱气器的钻井液排出口充满2/3钻井液为宜。", "options": ["正确", "错误"], "answer": 0, "analysis": ""}, {"id": 206, "type": "judge", "chapter": "综合题库", "stem": "钻井液温度、密度、电阻（导）率传感器安装，不必完全浸入钻井液液面，高度适中不易被沉砂埋没。", "options": ["正确", "错误"], "answer": 1, "analysis": "应完全浸入钻井液液面，高度适中，避免被沉砂埋没。"}, {"id": 207, "type": "judge", "chapter": "综合题库", "stem": "硫化氢传感器一般安装3个，分别装在钻台、缓冲罐和仪器房内，具体安装多少视现场需要而定。", "options": ["正确", "错误"], "answer": 0, "analysis": ""}, {"id": 208, "type": "judge", "chapter": "综合题库", "stem": "增压防爆系统正常启动后，应使录井仪器房内或远程钻台显示器内的空气压力高于外部压力50～150P1为宜。", "options": ["正确", "错误"], "answer": 0, "analysis": ""}, {"id": 209, "type": "judge", "chapter": "综合题库", "stem": "为保证漏电或过载时不损坏仪器设备，录井供电系统设置漏电、过载保护装置。", "options": ["正确", "错误"], "answer": 0, "analysis": ""}, {"id": 210, "type": "judge", "chapter": "综合题库", "stem": "立管压力缓慢降低、钻时保持不变、钻井液总池体积降低，可能是地面管线刺漏。", "options": ["正确", "错误"], "answer": 0, "analysis": ""}, {"id": 211, "type": "judge", "chapter": "综合题库", "stem": "综合录井仪控制系统，变压器主要是为了将外部供电380V或220V的交流电转换成能被综合录井仪内系统设备接受的交流电。", "options": ["正确", "错误"], "answer": 0, "analysis": ""}, {"id": 212, "type": "judge", "chapter": "综合题库", "stem": "原油在钻井液槽面上的显示特征:当其混入或侵入到钻井液中时，多呈褐黑色斑状油花，易集中，具油香味，且可使钻井液密度升高、粘度下降。", "options": ["正确", "错误"], "answer": 1, "analysis": "钻井液密度降低、粘度升高。"}, {"id": 213, "type": "judge", "chapter": "综合题库", "stem": "当井筒钻井液液柱压力低于地层孔隙压力时，在钻开储集层后，储集层的流体在压力的作用下侵入井筒钻井液，从而得以及时发现油气层，但如果钻井液液柱压力过低于地层孔隙压力，有可能发生井涌或井喷。", "options": ["正确", "错误"], "answer": 0, "analysis": ""}, {"id": 214, "type": "judge", "chapter": "综合题库", "stem": "危险化学品是指具有毒害、腐蚀、爆炸、燃烧、助燃等性质，对人体、设施、环境具有危害的剧毒化学品和其他化学品。", "options": ["正确", "错误"], "answer": 0, "analysis": ""}, {"id": 215, "type": "judge", "chapter": "综合题库", "stem": "钻井队在起下钻、检修设备、电测等非钻进过程中，录井人员应坚持坐岗观察，发现井漏、溢流应及时通知当班司钻，并录取井控相关资料、溢流取样分析、填报异常通知单。", "options": ["正确", "错误"], "answer": 0, "analysis": ""}, {"id": 216, "type": "judge", "chapter": "综合题库", "stem": "烘烤岩屑时可以不戴防护手套，开门时面向烤箱。", "options": ["正确", "错误"], "answer": 1, "analysis": "烘烤岩屑佩戴手套，开门时应避开烤箱。"}, {"id": 217, "type": "judge", "chapter": "综合题库", "stem": "定向造斜段施工时，应首先将方位角调整到设计方位角。当方位角偏差较大，随着井斜角增大，调整越晚，调整越困难，狗腿度越大，对井眼安全危害也越大。", "options": ["正确", "错误"], "answer": 0, "analysis": ""}, {"id": 218, "type": "judge", "chapter": "综合题库", "stem": "造斜点应选择在硬度适中、无坍塌、无缩径、无高压、无井漏等复杂情况的地层。", "options": ["正确", "错误"], "answer": 0, "analysis": ""}, {"id": 219, "type": "judge", "chapter": "综合题库", "stem": "进行电池筒拆卸作业时，对装有放气阀的电池筒，应首先缓慢卸松放气阀，确认没有带压气体持续泄出的现象后方可拆卸。", "options": ["正确", "错误"], "answer": 0, "analysis": ""}, {"id": 220, "type": "judge", "chapter": "综合题库", "stem": "使用过的锂电池组应及时从电池筒内取出，可以将放过电的锂电池组长时间留在电池筒中。", "options": ["正确", "错误"], "answer": 1, "analysis": "不得将放过电的锂电池组长时间留在电池筒中。"}, {"id": 221, "type": "judge", "chapter": "综合题库", "stem": "动力钻具井口测试、量角差、摆工具面时，可以站在转盘上。", "options": ["正确", "错误"], "answer": 1, "analysis": "不得站在转盘上。"}, {"id": 222, "type": "judge", "chapter": "综合题库", "stem": "在井口投放、取出多点杆件过程中,通知司钻严禁转动转盘。", "options": ["正确", "错误"], "answer": 0, "analysis": ""}, {"id": 223, "type": "judge", "chapter": "综合题库", "stem": "禁止在酒精灯燃烧状态下添加酒精,用完酒精灯后用要吹灭火焰。", "options": ["正确", "错误"], "answer": 1, "analysis": "用完酒精灯后用灯盖盖灭火焰。"}, {"id": 224, "type": "judge", "chapter": "综合题库", "stem": "钻开含硫化氢油气层后应每隔15分钟监测硫化氢浓度。", "options": ["正确", "错误"], "answer": 1, "analysis": "钻开硫化氢油气层后应连续监测。"}, {"id": 225, "type": "judge", "chapter": "综合题库", "stem": "定向井施工中，井斜角越小，使用高边工具面越准确。", "options": ["正确", "错误"], "answer": 1, "analysis": "井斜≤5°时应使用磁性工具面，高边工具面在小井斜时不稳定。"}, {"id": 226, "type": "judge", "chapter": "综合题库", "stem": "钻井液中含砂量过高不会影响MW4仪器的正常工作。", "options": ["正确", "错误"], "answer": 1, "analysis": "《作业指导书》4.2.1.2.1要求含砂量≤0.3%，过高会堵塞脉冲器、影响信号传输。"}, {"id": 227, "type": "judge", "chapter": "综合题库", "stem": "防碰井段施工中，若发现磁干扰，应立即停止钻进并上报。", "options": ["正确", "错误"], "answer": 0, "analysis": ""}, {"id": 228, "type": "judge", "chapter": "综合题库", "stem": "定向井施工中，浅层测试可以不接钻头进行。", "options": ["正确", "错误"], "answer": 0, "analysis": ""}, {"id": 229, "type": "judge", "chapter": "综合题库", "stem": "电子单多点投测时，可以同时开泵循环以加快投测速度。", "options": ["正确", "错误"], "answer": 1, "analysis": "《作业指导书》4.1.1.13规定严禁投入多点后开泵循环，以免损坏仪器。"}, {"id": 230, "type": "judge", "chapter": "综合题库", "stem": "定向井施工中，反扭角的大小与钻压、扭矩、井深等因素无关。", "options": ["正确", "错误"], "answer": 1, "analysis": "《作业指导书》4.4.1.2.5指出反扭角受扭矩、钻压、钻具刚性、井深等多种因素影响。"}, {"id": 231, "type": "judge", "chapter": "综合题库", "stem": "海蓝MW4仪器电池可以随意拆卸，无需特殊防护。", "options": ["正确", "错误"], "answer": 1, "analysis": "电池组不得短路、反接、过放电、焚烧或擅自拆解。"}, {"id": 232, "type": "judge", "chapter": "综合题库", "stem": "定向井施工中，工具面角是反映造斜工具面位置的重要参数。", "options": ["正确", "错误"], "answer": 0, "analysis": ""}, {"id": 233, "type": "judge", "chapter": "综合题库", "stem": "定向井完井资料可以完钻后统一录入EP2P系统，无需每班录入。", "options": ["正确", "错误"], "answer": 1, "analysis": "《作业指导书》6.3.1.3要求当班测斜数据每班必录，严禁完钻后批量录入。"}, {"id": 234, "type": "judge", "chapter": "综合题库", "stem": "螺杆钻具是一种将液体的压力能转换为机械能的装置。", "options": ["正确", "错误"], "answer": 0, "analysis": ""}, {"id": 235, "type": "judge", "chapter": "综合题库", "stem": "远程测控作业模式是指“前端交叉作业、后端远程支持”的新型作业形态。", "options": ["正确", "错误"], "answer": 1, "analysis": "远程测控作业模式是指“前端融合作业、后端远程支持”的新型作业形态。"}, {"id": 236, "type": "judge", "chapter": "综合题库", "stem": "当钻井液中发现极少量的原油时，可以不做钻井液荧光检查试验。", "options": ["正确", "错误"], "answer": 1, "analysis": "当钻井液中发现极少量的原油时，也应按标准程序对钻井液荧光进行检查试验。"}, {"id": 237, "type": "judge", "chapter": "综合题库", "stem": "储集层就是储集有油气的岩层。", "options": ["正确", "错误"], "answer": 1, "analysis": "储集层是指具备孔隙空间和渗透能力，能够储存并允许流体（油、气、水）流动的岩层。"}, {"id": 238, "type": "judge", "chapter": "综合题库", "stem": "沉积岩的致密程度较岩浆岩、变质岩高。", "options": ["正确", "错误"], "answer": 1, "analysis": "沉积岩的致密程度通常低于岩浆岩、变质岩。"}, {"id": 239, "type": "judge", "chapter": "综合题库", "stem": "X衍射分析含粘土矿物的样品时，需特别注意避免高温处理。", "options": ["正确", "错误"], "answer": 0, "analysis": ""}]